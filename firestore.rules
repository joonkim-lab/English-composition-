rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // ★ 이메일 화이트리스트
    //   index.html ①설정 블록(FAMILY + TEACHER_EMAILS)과
    //   반드시 똑같이 맞춰주세요. (수정 위치 2곳 중 하나)
    // ──────────────────────────────────────────────
    function isFamily() {
      return request.auth != null &&
        request.auth.token.email in [
          "child10@example.com",   // 첫째 (10학년)
          "child8@example.com",    // 둘째 (8학년)
          "child6@example.com",    // 셋째 (6학년)
          "junkim@example.com"     // 준킴쌤 (관리자)
        ];
    }

    // 본인 문서인지 확인
    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── 사용자 진도 문서 ──
    // users/{uid} : 레벨, 완료 유닛, 시험 기록
    // 읽기: 가족 전원 (가족 보드에서 서로의 진도를 봄)
    // 쓰기: 본인만
    match /users/{uid} {
      allow read:  if isFamily();
      allow write: if isFamily() && isSelf(uid);
    }

    // ── 일일 기록 문서 ──
    // logs/{uid_YYYY-MM-DD} : 그날 완료한 유닛 목록
    // 문서 ID가 "uid_날짜" 형태이므로, 쓰기는 본인 uid로 시작하는 문서만 허용
    match /logs/{logId} {
      allow read:  if isFamily();
      allow write: if isFamily() &&
        logId.split('_')[0] == request.auth.uid &&
        request.resource.data.uid == request.auth.uid;
    }

    // 그 외 모든 경로는 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
